# Backend Environment Configuration
# Copy to .env and fill in actual values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/foodstore

# Security
SECRET_KEY=your-secret-key-change-this-in-production-min-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MercadoPago
MP_ACCESS_TOKEN=TEST-your-mercadopago-access-token
MP_PUBLIC_KEY=TEST-your-mercadopago-public-key
MP_NOTIFICATION_URL=https://your-domain.com/api/v1/pagos/webhook
MP_WEBHOOK_SECRET=

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Server
DEBUG=True
ENVIRONMENT=development
